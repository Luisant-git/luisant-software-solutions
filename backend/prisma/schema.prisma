generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   Product[]
  clients    Client[]
  portfolios Portfolio[]

  @@map("admins")
}

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String   @db.Text
  points          String[] @default([])
  buttonName      String?
  buttonUrl       String?
  banner          String?  @db.Text
  adminId         String
  admin           Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("products")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logo      String   @db.Text
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Career {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  email     String
  city      String?
  skills    String?  @db.Text
  resumeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("careers")
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  category    String
  image       String   @db.Text
  images      String[] @default([])
  clientName  String?
  technologies String[] @default([])
  features    String[] @default([])
  link        String?
  caseStudy   String?  @db.Text
  results     String[] @default([])
  adminId     String
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("portfolios")
}
